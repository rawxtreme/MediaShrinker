<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050816">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- LOGO -->

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_ms"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"/>

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MediaShrinker"
            android:textColor="#3B82F6"
            android:textStyle="bold"
            android:textSize="34sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"/>

        <!-- VERSION -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Version 4.0"
            android:textColor="#00E5FF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"/>

        <!-- ABOUT CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/history_card_bg"
            android:padding="20dp"
            android:layout_marginTop="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About App"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MediaShrinker is a modern Android image compression app designed for fast, smart and high quality image optimization.\n\nThe app now supports batch compression, smart PNG detection, live compression slider and compression history.\n\nThe app is continuously improving with new powerful features and better optimization updates.\n\nMediaShrinker does not collect personal user data.All image processing happens locally on the device.No images are uploaded to servers.Compression history is stored only on the user's device.For more information, please contact developer on instagram.\n\nFeatures Explaination : \n\n1) Please not that in compare images button, you are able to compare only one image as the app is focused on optimization so limit this to one. You can also compare manually in your gallery.\n\n2) Please ignore the Coming Soon title in about app as the app is now finished and fully developed. In future, only the glitches will be fixed. No other features will be added. If someone want, you can still tell me on instagram so I can work on it😅.\n\n3) All features were manually tested by the developer and no glitches and bugs are found so far, if you have found one, please tell the me on Instagram. If you have suggestions then please tell me only on the Give Suggestions option in the app.\n\n4) If you want to let my work carry on, please buy me a coffee so I can develop more apps in future for you.\n\n5) Important : Video Compressor is not working, as I added this feature just for testing and in result it's failed. \n\nThank You💖"
                android:textColor="#D1D5DB"
                android:textSize="16sp"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

        <!-- COMING SOON -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/history_card_bg"
            android:padding="20dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coming Soon"
                android:textColor="#00FFB7"
                android:textStyle="bold"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Multiple Photos to PDF\n• AI Compression\n• Premium Compression Modes\n• Better Batch Processing\n• More UI Animations\n• Advanced Optimization"
                android:textColor="#D1D5DB"
                android:textSize="16sp"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

        <!-- DEVELOPER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/history_card_bg"
            android:padding="20dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aaditya Shukla 🥂"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="28sp"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

        <!-- BUTTONS -->

        <Button
            android:id="@+id/instagramButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="INSTAGRAM"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/share_button_bg"
            android:layout_marginTop="30dp"/>

        <Button
            android:id="@+id/githubButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="GITHUB"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/open_button_bg"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="40dp"/>

    </LinearLayout>

</ScrollView>