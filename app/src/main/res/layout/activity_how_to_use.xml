<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050816">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF"
            android:padding="6dp"
            android:background="@drawable/card_bg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="16dp"
            android:text="How to Use"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- New Features Highlight -->
            <TextView
                android:id="@+id/newFeaturesBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="✨ New Features Explained ✨"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/new_features_badge_bg"
                android:layout_marginBottom="14dp" />

            <!-- Intro -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MediaShrinker v8.0 — Complete Guide"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This app lets you compress images, convert formats, resize photos, create PDFs, and remove metadata — all offline, right on your phone."
                android:textColor="#AAFFFFFF"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Feature 1: Compress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗜️  Compress Images"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 → Tap 'Select Images' on the main screen.\nStep 2 → Choose one or multiple images from your gallery.\nStep 3 → Enter your target size in KB (e.g. 200).\nStep 4 → Choose a compression mode:\n     • Ultra Quality — Best quality, light compression (95%)\n     • Balanced — Good balance of size and quality (75%)\n     • Max Compression — Smallest file size (40%)\nStep 5 → Or drag the Quality slider manually.\nStep 6 → Tap 'Compress' button.\nStep 7 → Done! Image saved in Gallery → DCIM → MediaShrinker."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- Feature 1.5: Smart Photo Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📸  Smart Photo Selection"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 → Tap 'Select Photos' — this opens the app's own built-in photo picker (no other app opens).\nStep 2 → Tap any photo to select it. A blue checkmark badge appears on it.\nStep 3 → You can select up to 100 photos at once. Once 100 are selected, the remaining photos dim out and can't be tapped until you remove one first.\nStep 4 → Tap 'Done' to confirm your selection.\n\nFirst time you open this screen, Android will ask for a Photos permission — please allow it so the app can show your gallery. If you accidentally deny it, a popup will guide you to enable it from Settings."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- Feature 1.6: Preview & Remove Photos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖼️  Preview &amp; Remove Selected Photos"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="If you selected only 1 photo → a small ✕ button appears on the photo preview. Tap it to remove that photo and pick a different one.\n\nIf you selected 2 or more photos → a 'Preview' button appears instead. Tap it to open a full screen showing all your selected photos in a grid, each with its own ✕ button.\n\nRemove any photo you don't want, then tap 'Continue to Home Screen' to return and proceed with compression or PDF creation."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- Feature 2: PDF -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄  Create PDF from Images"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 → Select one or more images using 'Select Photos'.\nStep 2 → Tap 'Create PDF' button.\nStep 3 → A progress popup with a progress bar appears, showing how many photos have been processed.\nStep 4 → The PDF will be saved in Documents → MediaShrinker.\nStep 5 → A PDF viewer will open automatically if available.\n\nTip: You can select up to 50 photos at once to combine them into a single PDF."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />
					
            </LinearLayout>

            <!-- Feature 3: Resize -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📐  Resize Image"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 → Open the side drawer menu (tap ☰ top-left).\nStep 2 → Tap 'Resize Image'.\nStep 3 → Select an image from your gallery.\nStep 4 → Choose a preset size:\n     • 1080 × 1080 — Full HD square\n     • 720 × 720 — HD square\n     • 512 × 512 — Small square\nStep 5 → Resized image saved in Gallery → DCIM → MediaShrinker."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- Feature 4: Format Converter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄  Format Converter"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 → Open the drawer menu and tap 'Format Converter'.\nStep 2 → Select an image.\nStep 3 → Choose your conversion:\n     • PNG → JPG\n     • JPG → PNG\n     • WEBP → JPG\n     • WEBP → PNG\nStep 4 → Tap 'Convert'.\nStep 5 → File saved in Gallery → DCIM → MediaShrinker → Converted."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- Feature 5: Metadata Remover -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔏  Metadata Remover"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This removes hidden EXIF data from your images (location, device info, date, camera settings etc.).\n\nStep 1 → Open drawer → tap 'Metadata Remover'.\nStep 2 → Select an image.\nStep 3 → Tap 'Remove Metadata'.\nStep 4 → Clean image saved in Gallery → DCIM → MediaShrinker → CleanImages.\n\nTip: Always remove metadata before sharing photos publicly to protect your privacy."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- Feature 6: Compare -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚖️  Compare Before / After"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 → First compress an image.\nStep 2 → Tap 'Compare' button on the main screen.\nStep 3 → You will see the original and compressed image side by side.\n\nThis helps you visually judge quality vs size tradeoff."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- Feature 6.5: Image Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️  Image Info (EXIF Details)"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 → Select an image and tap 'Image Info'.\nStep 2 → App will show file name, size, resolution, format, camera make/model, flash and focal length — all read directly from the photo's hidden EXIF data.\n\nThis works fully offline, no internet is used, and no personal location data is read or shown."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- Feature 7: History -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋  History"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Compression History → Shows all previously compressed images with original size, compressed size, and reduction %.\n\n• PDF History → Shows all PDFs created using the app.\n\nBoth are accessible from the side drawer menu."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- Feature 8: Email to Developer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📧 Email to Developer"
                    android:textColor="#3B82F6"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please Note:\n\nWhen you tap the &quot;Give Suggestions&quot; option from the three-line menu, some basic device information will be added to your email automatically. This may include your Device Model, Device Manufacturer, Android Version, App Version, Date, and Time. This information helps me understand your device better and allows me to solve your issue, improve the app, or understand your suggestions more accurately.\n\nPlease do not remove this information, as it is very helpful during troubleshooting and development.\n\nYour privacy is important. The automatically added information is used only to understand your device and provide better support. No sensitive or personal data is collected through this feature.\n\nIf you would like to know more or contact me directly, you can use the &quot;Contact Developer&quot; option or visit my Instagram profile from the &quot;About App&quot; section.\n\nPlease note: At the moment, I can only be contacted through Instagram. If I am unable to reply to your message immediately, please don't worry. I read every message and will respond as soon as I am available.\n\nThank you very much for your support and cooperation! ❤️"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>