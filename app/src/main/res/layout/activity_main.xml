<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050816">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- TOP BAR -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/menuButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☰"
                    android:textColor="#3B82F6"
                    android:textSize="30sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_ms"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  MediaShrinker"
                    android:textColor="#3B82F6"
                    android:textSize="28sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart image compression for modern Android"
                android:textColor="#7C8BA1"
                android:textSize="15sp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="26dp"/>

            <!-- IMAGE CARD -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEDIA SHRINKER"
                    android:textColor="#D6E4FF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp"/>

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerCrop"
                    android:background="#0A1020"/>

                <Button
                    android:id="@+id/selectImageButton"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="SELECT PHOTOS"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/button_bg"
                    android:layout_marginTop="18dp"/>
            </LinearLayout>

            <!-- TARGET SIZE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TARGET SIZE (KB)"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/targetSizeInput"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/input_bg"
                android:hint="Example: 200"
                android:padding="18dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#6F7D95"
                android:textSize="16sp"
                android:inputType="number"/>

            <!-- AI COMPRESSION MODES -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI COMPRESSION MODES"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="14dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <Button
                    android:id="@+id/ultraModeButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="ULTRA"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_bg"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/balancedModeButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="BALANCED"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/pdf_button_bg"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"/>

                <Button
                    android:id="@+id/maxModeButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="MAX"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/compare_button_bg"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <!-- QUALITY -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMPRESSION QUALITY"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"/>

            <SeekBar
                android:id="@+id/qualitySeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="80"/>

            <TextView
                android:id="@+id/qualityText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quality: 80%"
                android:textColor="#00E5FF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"/>

            <!-- INFO CARD -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginTop="24dp">

                <TextView
                    android:id="@+id/originalSizeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B6C2D9"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/compressedSizeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#3B82F6"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#00FFB7"
                    android:textSize="16sp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

            <!-- ANALYTICS CARD -->

            <LinearLayout
                android:id="@+id/analyticsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="20dp"
                android:layout_marginTop="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STORAGE ANALYTICS"
                    android:textColor="#00E5FF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/storageSavedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saved Space:"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/reductionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reduction:"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/resolutionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resolution:"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/formatText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Format:"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>

            </LinearLayout>

            <!-- BUTTONS -->

            <Button
                android:id="@+id/compressButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="COMPRESS NOW"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_bg"
                android:layout_marginTop="28dp"/>

            <Button
                android:id="@+id/shareButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SHARE COMPRESSED IMAGE"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_bg"
                android:layout_marginTop="18dp"/>

            <Button
                android:id="@+id/openFolderButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="OPEN COMPRESSED FOLDER"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_bg"
                android:layout_marginTop="18dp"/>

            <Button
                android:id="@+id/compareButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="COMPARE IMAGES"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/compare_button_bg"
                android:layout_marginTop="18dp"/>

            <Button
                android:id="@+id/createPdfButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="CREATE PDF"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/pdf_button_bg"
                android:layout_marginTop="18dp"/>

        </LinearLayout>

    </ScrollView>

    <!-- SIDEBAR -->

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#0B1220"
        android:padding="24dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_ms"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MediaShrinker"
            android:textColor="#3B82F6"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="40dp"/>

        <TextView
            android:id="@+id/contactDeveloperOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Developer"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/instagramOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instagram"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/aboutAppOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About App"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/suggestionOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Give Suggestions"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/historyOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compression History"
            android:textColor="#00E5FF"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/pdfHistoryOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PDF History"
            android:textColor="#FF4D8D"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/resizeOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Image Resizer"
            android:textColor="#FFD54F"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/videoCompressorOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Video Compressor"
            android:textColor="#FF7043"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/buyCoffeeOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buy Me A Coffee ☕"
            android:textColor="#FFFFFF"
            android:textSize="20sp"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>