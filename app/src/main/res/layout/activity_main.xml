<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050816">

    <!-- ===== MAIN CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/menuButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☰"
                    android:textColor="#3B82F6"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:padding="4dp" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginLeft="12dp"
                    android:src="@drawable/ic_ms" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    android:text="MediaShrinker"
                    android:textColor="#3B82F6"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v7.1"
                    android:textColor="#3B82F6"
                    android:textSize="12sp"
                    android:background="@drawable/card_bg"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

            </LinearLayout>

            <!-- IMAGE PREVIEW CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:background="#0A1020" />

                <Button
                    android:id="@+id/selectImageButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="SELECT PHOTOS"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/button_bg"
                    android:layout_marginTop="12dp"
                    android:stateListAnimator="@null" />

                <!-- Custom Save Location -->
                <TextView
                    android:id="@+id/saveFolderText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📁 Save to: DCIM/MediaShrinker  (tap to change)"
                    android:textColor="#88FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:padding="10dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_bg" />

            </LinearLayout>

            <!-- TARGET SIZE + QUALITY in one row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Target Size -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="12dp"
                    android:layout_marginRight="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TARGET SIZE (KB)"
                        android:textColor="#3B82F6"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/targetSizeInput"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/input_bg"
                        android:hint="e.g. 200"
                        android:padding="10dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#6F7D95"
                        android:textSize="14sp"
                        android:inputType="number" />

                </LinearLayout>

                <!-- Quality -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="12dp"
                    android:layout_marginLeft="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUALITY"
                        android:textColor="#3B82F6"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/qualityText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="80%"
                        android:textColor="#00E5FF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <SeekBar
                        android:id="@+id/qualitySeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="80" />

                </LinearLayout>

            </LinearLayout>

            <!-- COMPRESSION MODE BUTTONS — 3 in a row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/ultraModeButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="⚡ Ultra"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_bg"
                    android:layout_marginRight="4dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/balancedModeButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="⚖️ Balanced"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/pdf_button_bg"
                    android:layout_marginLeft="2dp"
                    android:layout_marginRight="2dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/maxModeButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="🔥 Max"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/compare_button_bg"
                    android:layout_marginLeft="4dp"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- STATS CARD — 2x2 grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <!-- Original Size -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/input_bg"
                        android:padding="10dp"
                        android:layout_marginRight="5dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ORIGINAL"
                            android:textColor="#7C8BA1"
                            android:textSize="10sp"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/originalSizeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#B6C2D9"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <!-- Compressed Size -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/input_bg"
                        android:padding="10dp"
                        android:layout_marginLeft="5dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COMPRESSED"
                            android:textColor="#7C8BA1"
                            android:textSize="10sp"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/compressedSizeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#3B82F6"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Saved + Reduction -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/input_bg"
                        android:padding="10dp"
                        android:layout_marginRight="5dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SAVED"
                            android:textColor="#7C8BA1"
                            android:textSize="10sp"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/storageSavedText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#00FFB7"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/reductionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#00E5FF"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <!-- Resolution + Format -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/input_bg"
                        android:padding="10dp"
                        android:layout_marginLeft="5dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INFO"
                            android:textColor="#7C8BA1"
                            android:textSize="10sp"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/resolutionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/formatText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Result text -->
                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#00FFB7"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="10dp" />

            </LinearLayout>

            <!-- Preview Quality Button -->
            <Button
                android:id="@+id/previewQualityButton"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="🔍  Preview Estimated Size"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#3B82F6"
                android:background="@drawable/input_bg"
                android:layout_marginBottom="10dp"
                android:stateListAnimator="@null" />

            <!-- ACTION BUTTONS — COMPRESS full width -->
            <Button
                android:id="@+id/compressButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="⚡  COMPRESS NOW"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_bg"
                android:layout_marginBottom="10dp"
                android:stateListAnimator="@null" />

            <!-- Share + Open Folder — 2 in a row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/shareButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📤 Share"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_bg"
                    android:layout_marginRight="6dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/openFolderButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📁 Folder"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_bg"
                    android:layout_marginLeft="6dp"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- Compare + Create PDF — 2 in a row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/compareButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="⚖️ Compare"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/compare_button_bg"
                    android:layout_marginRight="6dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/createPdfButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📄 Create PDF"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/pdf_button_bg"
                    android:layout_marginLeft="6dp"
                    android:stateListAnimator="@null" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ===== SIDEBAR DRAWER ===== -->
    <ScrollView
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0B1220"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="52dp"
            android:paddingBottom="24dp"
            android:paddingLeft="20dp"
            android:paddingRight="20dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_ms"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MediaShrinker"
                android:textColor="#3B82F6"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v7.1"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="28dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF"
                android:layout_marginBottom="20dp" />

            <!-- Section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECT"
                android:textColor="#3B82F6"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/contactDeveloperOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✉  Contact Developer"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/instagramOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📸  Instagram"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/aboutAppOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ  About App"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/suggestionOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡  Give Suggestions"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="16dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOOLS"
                android:textColor="#3B82F6"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/historyOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🗜  Compression History"
                android:textColor="#00E5FF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/pdfHistoryOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📄  PDF History"
                android:textColor="#FF4D8D"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/resizeOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📐  Image Resizer"
                android:textColor="#FFD54F"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/formatConverterOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔄  Format Converter"
                android:textColor="#00FFB7"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/metadataRemoverOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔏  Metadata Remover"
                android:textColor="#FF9800"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/analyticsOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📊  Storage Analytics"
                android:textColor="#A78BFA"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/imageInfoOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ️  Image Info"
                android:textColor="#60A5FA"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="16dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MORE"
                android:textColor="#3B82F6"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/settingsOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚙  Settings"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/buyCoffeeOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="☕  Buy Me A Coffee"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="10dp" />

        </LinearLayout>

    </ScrollView>

</androidx.drawerlayout.widget.DrawerLayout>