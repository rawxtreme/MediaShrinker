<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050816">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF"
            android:padding="6dp"
            android:background="@drawable/card_bg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="16dp"
            android:text="Privacy Policy"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last updated: 2nd July 2026"
                android:textColor="#88FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="20dp" />

            <!-- Section 1 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Introduction"
                android:textColor="#3B82F6"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome to MediaShrinker. This Privacy Policy explains how the app handles your information. MediaShrinker is a free, offline image compression and conversion tool developed by Aaditya Shukla. By using this app, you agree to this policy."
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Section 2 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Data We Collect"
                android:textColor="#3B82F6"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MediaShrinker does NOT collect, store, or transmit any personal data to external servers. All image processing happens entirely on your device.\n\nThe app only stores the following data locally on your device:\n\n• Compression history (stored in app's private SharedPreferences)\n• PDF creation history (stored locally)\n• Your settings preferences (startup video on/off)\n\nNone of this data ever leaves your device."
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Section 3 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Permissions Used"
                android:textColor="#3B82F6"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• READ_EXTERNAL_STORAGE — To read images from your gallery for compression/conversion.\n\n• WRITE_EXTERNAL_STORAGE — To save compressed images and PDFs to your device.\n\n• INTERNET — Only used to check for app updates from GitHub. No personal data is sent.\n\nThese permissions are used solely for core app functionality."
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Section 4 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4. Third-Party Services"
                android:textColor="#3B82F6"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The app uses the GitHub API (api.github.com) only when you manually tap 'Check for Updates' in Settings. This request only fetches the latest release version tag — no personal data is included in this request.\n\nThe app does not use any analytics, ads, or tracking SDKs."
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Section 5 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5. Children's Privacy"
                android:textColor="#3B82F6"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MediaShrinker does not knowingly collect any information from children under the age of 13. The app is safe for all ages."
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Section 6 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6. Changes to This Policy"
                android:textColor="#3B82F6"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We may update this Privacy Policy occasionally. Changes will be reflected here with an updated date."
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Section 7 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7. Contact"
                android:textColor="#3B82F6"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="If you have any questions about this Privacy Policy, you can contact the developer:\n\n• Instagram: @carryon.aditya\n• scope8xaditya@gmail.com\n• GitHub: github.com/rawxtreme"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="40dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
