<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/card_bg">

    <TextView
        android:id="@+id/newActivityIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:text="🔄"
        android:textSize="26sp"
        android:gravity="center"
        android:background="@drawable/icon_bg_blue"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/newActivityTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="What's Next?"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/newActivityMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Would you like to start a new activity with fresh photos, or keep working with your current selection?"
        android:textColor="#B0BEC5"
        android:textSize="13sp"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/newActivityNoBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginRight="8dp"
            android:text="No, Keep This"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_cancel_bg" />

        <Button
            android:id="@+id/newActivityYesBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginLeft="8dp"
            android:text="Yes, Start New"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/button_bg" />

    </LinearLayout>

</LinearLayout>
