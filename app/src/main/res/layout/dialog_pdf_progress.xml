<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/card_bg">

    <TextView
        android:id="@+id/pdfProgressIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:text="📄"
        android:textSize="26sp"
        android:gravity="center"
        android:background="@drawable/icon_bg_blue"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/pdfProgressTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Creating PDF..."
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <ProgressBar
        android:id="@+id/pdfProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        android:progressTint="#3B82F6"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/pdfProgressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="0 / 0 photos processed"
        android:textColor="#B0BEC5"
        android:textSize="13sp" />

</LinearLayout>