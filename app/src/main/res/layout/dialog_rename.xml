<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/card_bg">

    <TextView
        android:id="@+id/renameDialogIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:text="✏️"
        android:textSize="26sp"
        android:gravity="center"
        android:background="@drawable/icon_bg_blue"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Rename File"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/renameInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. my_photo"
        android:textColor="#FFFFFF"
        android:textColorHint="#88FFFFFF"
        android:background="@drawable/input_bg"
        android:padding="12dp"
        android:textSize="14sp"
        android:layout_marginBottom="20dp"
        android:inputType="text"
        android:singleLine="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/renameCancelBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginRight="8dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_cancel_bg" />

        <Button
            android:id="@+id/renameConfirmBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginLeft="8dp"
            android:text="Rename"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/button_bg" />

    </LinearLayout>

</LinearLayout>
