<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/card_bg">

    <TextView
        android:id="@+id/saveLocationIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:text="📁"
        android:textSize="26sp"
        android:gravity="center"
        android:background="@drawable/icon_bg_blue"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Save Location"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="18dp" />

    <!-- Option 0 -->
    <LinearLayout
        android:id="@+id/saveLocOption0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/save_option_bg"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/saveLocCheck0"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/radio_unselected_bg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="12dp"
            android:text="Gallery → DCIM/MediaShrinker"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Option 1 -->
    <LinearLayout
        android:id="@+id/saveLocOption1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/save_option_bg"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/saveLocCheck1"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/radio_unselected_bg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="12dp"
            android:text="Pictures/MediaShrinker"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Option 2 -->
    <LinearLayout
        android:id="@+id/saveLocOption2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/save_option_bg"
        android:layout_marginBottom="18dp">

        <TextView
            android:id="@+id/saveLocCheck2"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/radio_unselected_bg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="12dp"
            android:text="Downloads/MediaShrinker"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/saveLocCancelBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginRight="8dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_cancel_bg" />

        <Button
            android:id="@+id/saveLocSaveBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginLeft="8dp"
            android:text="Save"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/button_bg" />

    </LinearLayout>

</LinearLayout>
