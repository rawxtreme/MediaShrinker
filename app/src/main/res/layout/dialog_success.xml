<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center"
    android:background="@drawable/card_bg">

    <!-- Animated Checkmark -->
    <TextView
        android:id="@+id/successIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:text="✓"
        android:textColor="#00FFB7"
        android:textSize="40sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/icon_bg_green"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/successTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Compression Complete!"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/successSaved"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saved 0 KB"
        android:textColor="#00FFB7"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/successReduction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reduced by 0%"
        android:textColor="#3B82F6"
        android:textSize="13sp"
        android:layout_marginBottom="24dp" />

    <!-- 3 Action Buttons -->
    <Button
        android:id="@+id/successShareBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="📤  Share Now"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/button_bg"
        android:stateListAnimator="@null"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/successRenameBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="✏️  Rename File"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/compare_button_bg"
        android:stateListAnimator="@null"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/successDoneBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Done"
        android:textAllCaps="false"
        android:textColor="#88FFFFFF"
        android:textSize="15sp"
        android:background="@drawable/card_bg"
        android:stateListAnimator="@null" />

</LinearLayout>
